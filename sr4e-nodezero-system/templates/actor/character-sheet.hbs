<form class="sr4e actor-sheet {{actor.type}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
    <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="main">Main</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="gear">Gear</a>
    <a class="item" data-tab="matrix">Matrix</a>
    <a class="item" data-tab="astral">Astral</a>
    <a class="item" data-tab="rigging">Rigging</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="main">{{> "systems/sr4e-nodezero/templates/parts/actor-main.hbs"}}</div>
    <div class="tab" data-group="primary" data-tab="skills">{{> "systems/sr4e-nodezero/templates/parts/actor-skills.hbs"}}</div>
    <div class="tab" data-group="primary" data-tab="gear">{{> "systems/sr4e-nodezero/templates/parts/actor-gear.hbs"}}</div>
    <div class="tab" data-group="primary" data-tab="matrix">{{> "systems/sr4e-nodezero/templates/parts/actor-matrix.hbs"}}</div>
    <div class="tab" data-group="primary" data-tab="astral">{{> "systems/sr4e-nodezero/templates/parts/actor-astral.hbs"}}</div>
    <div class="tab" data-group="primary" data-tab="rigging">{{> "systems/sr4e-nodezero/templates/parts/actor-rigging.hbs"}}</div>
  </section>
</form>
